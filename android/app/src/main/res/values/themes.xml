<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Solvio" parent="android:Theme.Material.Light.NoActionBar">
        <!-- Compose handles all theming in code; this base just removes the system action bar
             and sets a transparent status bar so MainActivity can edge-to-edge. -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
</resources>
