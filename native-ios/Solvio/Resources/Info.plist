<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>pl</string>
	<key>CFBundleDisplayName</key>
	<string>Solvio</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleLocalizations</key>
	<array>
		<string>pl</string>
		<string>en</string>
	</array>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<false/>
	</dict>
	<key>NSCameraUsageDescription</key>
	<string>Solvio potrzebuje kamery do skanowania paragonów (OCR).</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Solvio może zapisywać wygenerowane raporty i e-paragony do Twojej galerii.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Solvio potrzebuje dostępu do zdjęć aby przesłać paragon do analizy.</string>
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string>LaunchBackground</string>
	</dict>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<!-- Portrait-only is intentional (iPhone-first UX). Setting
	     UIRequiresFullScreen=true silences Xcode's "All interface
	     orientations must be supported unless the app requires full
	     screen" warning by declaring that we don't support iPad
	     multitasking modes (Slide Over / Split View). -->
	<key>UIRequiresFullScreen</key>
	<true/>
</dict>
</plist>
